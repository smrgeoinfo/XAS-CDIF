  "@id": "https://w3id.org/cdif/xas/fluorescenceintensity",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Fluorescence intensity",
    "@language": "en"
  },
  "notation": "ifluor",
  "definition": {
    "@value": "A measured X-ray intensity emitted by a sample, following absorption of incident X-rays, due to fluorescence decay phenomena.",
    "@language": "en"
  },
  "note": {
    "@value": "Fluorescence is a physical phenomena.  When X-rays are absorbed by a sample, they create excited electronic states.  These states can decay, and one of the decay proceses is flourescence.  When excited electrons decay in an atom by fluorescence, they emitt light, in this case, is X-ray light. (https://www.lehigh.edu/imi/teched/GlassCSC/SuppReading/Tutorials.pdf)",
    "@language": "en"
  },
  "inScheme": {
    "@id": "https://w3id.org/cdif/xas/CDIF4XAS_Reference_Concepts"
  },
  "references": [
    "https://github.com/XraySpectroscopy/XAS-Data-Interchange/blob/master/specification/dictionary.md",
    "https://en.wikipedia.org/wiki/X-ray_fluorescence",
    "https://doi.org/10.5281/zenodo.14920226"
  ]
}
