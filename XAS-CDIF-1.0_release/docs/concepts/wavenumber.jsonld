  "@id": "https://w3id.org/cdif/xas/wavenumber",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Wavenumber",
    "@language": "en"
  },
  "notation": "k",
  "definition": {
    "@value": "The photoelectron wavenumber (k) represents the spatial frequency of the emitted photoelectron wave, calculated from the kinetic energy above the absorption edge.",
    "@language": "en"
  },
  "note": {
    "@value": "XDI Column.k: photoelectron wavenumber (typically inverse Angstroms).",
    "@language": "en"
  },
  "inScheme": {
    "@id": "https://w3id.org/cdif/xas/CDIF4XAS_Reference_Concepts"
  },
  "references": [
    "Bunker, G. (2010). Introduction to X-ray Absorption Fine Structure Spectroscopy. Cambridge University Press.",
    "https://en.wikipedia.org/wiki/Wavenumber",
    "https://doi.org/10.5281/zenodo.14920226"
  ]
}
