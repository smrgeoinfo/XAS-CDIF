  "@id": "https://w3id.org/cdif/xas/energyerror",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Energy error",
    "@language": "en"
  },
  "definition": {
    "@value": "The difference between the intended energy selected by a monochromator and the actual energy measured at the sample (the incident intensity)",
    "@language": "en"
  },
  "note": {
    "@value": "NEXUS comment is 'energy standard deviation' (nxs: Field/NXmonochromator/energy_error), or 'uncertaities associated to energy' (from https://github.com/nexusformat/definitions/issues/820); note this is apparently different from our definition here.",
    "@language": "en"
  },
  "inScheme": {
    "@id": "https://w3id.org/cdif/xas/CDIF4XAS_Reference_Concepts"
  },
  "seeAlso": "https://manual.nexusformat.org/classes/base_classes/NXmonochromator.html#nxmonochromator-energy-error-field",
  "foaf:focus": {
    "@id": "http://purl.org/nexusformat/definitions/Field/NXmonochromator/energy_error"
  },
  "references": "https://doi.org/10.5281/zenodo.14920226"
}
