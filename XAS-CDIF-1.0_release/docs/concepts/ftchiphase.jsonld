  "@id": "https://w3id.org/cdif/xas/ftchiphase",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Fourier-transformed chi phase",
    "@language": "en"
  },
  "notation": "chir_pha",
  "definition": {
    "@value": "Phase of the Fourier-transformed Extended X-ray Absorption Fine Structure (EXAFS) oscillations chi(R) in R-space, obtained without applying corrections for phase shifts.",
    "@language": "en"
  },
  "note": {
    "@value": "XDI Column.chir_pha: phase of Fourier transform of chi(k).",
    "@language": "en"
  },
