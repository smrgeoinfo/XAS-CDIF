  "@id": "https://w3id.org/cdif/xas/calibrationmethod",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Detector calibration method",
    "@language": "en"
  },
  "definition": {
    "@value": "Information detailing how raw detector signals were mathematically mapped into final pixel coordinates or energy bins, identifies the mathematical models used to correct spatial or geometric distortions (such as polynomial equations) and provides a reference link or file path to the exact coefficients and calibration logs used during data processing. (edited from Google AI)",
    "@language": "en"
  },
