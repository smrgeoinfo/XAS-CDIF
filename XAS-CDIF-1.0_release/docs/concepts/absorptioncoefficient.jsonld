  "@id": "https://w3id.org/cdif/xas/absorptioncoefficient",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Absorption coefficient",
    "@language": "en"
  },
  "notation": "mutrans",
  "definition": {
    "@value": "A coefficient μ(E) calculated as the natural log of the ratio of incident over transmitted x-ray intensity, divided by the thickness of the sample.",
