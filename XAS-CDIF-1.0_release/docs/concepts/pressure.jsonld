  "@id": "https://w3id.org/cdif/xas/pressure",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Pressure",
    "@language": "en"
  },
  "definition": {
    "@value": "Normal force acting on a surface divided by the area of that surface. ",
    "@language": "en"
  },
  "note": {
    "@value": "Environmental condition of sample during analysis. For a mixture of gases the contribution by each constituent is called the 'partial pressure'.  https://doi.org/10.1351/goldbook.P04819",
    "@language": "en"
  },
  "inScheme": {
    "@id": "https://w3id.org/cdif/xas/CDIF4XAS_Reference_Concepts"
  },
  "seeAlso": "https://manual.nexusformat.org/classes/base_classes/NXsample.html#nxsample-pressure-field",
  "foaf:focus": {
    "@id": "http://purl.org/nexusformat/definitions/Field/NXsample/pressure"
  },
  "references": [
    " https://doi.org/10.1351/goldbook.P04819",
