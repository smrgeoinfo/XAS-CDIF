  "@id": "https://w3id.org/cdif/xas/exafsfunction",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "EXAFS function chi(k)",
    "@language": "en"
  },
  "notation": "chi",
  "definition": {
    "@value": "A function representing the Extended X-ray Absorption Fine Structure (EXAFS) oscillations in k-space  It represents the modulation of the X-ray absorption coefficient (isolated and normalized) due to the scattering of a photoelectron wave by neighboring atoms, expressed as a function of the photoelectron wavevector (k).",
    "@language": "en"
  },
  "note": {
    "@value": "XDI Column.chi: EXAFS oscillatory function chi(k).",
    "@language": "en"
  },
  "inScheme": {
    "@id": "https://w3id.org/cdif/xas/CDIF4XAS_Reference_Concepts"
  },
  "references": [
    "Ravel, B., & Newville, M. (2005). ATHENA, ARTEMIS, HEPHAESTUS: data analysis for X-ray absorption spectroscopy using IFEFFIT. Journal of Synchrotron Radiation, 12(4), 537-541.",
    "https://en.wikipedia.org/wiki/Extended_X-ray_absorption_fine_structure",
    "https://doi.org/10.5281/zenodo.14920226"
  ]
}
