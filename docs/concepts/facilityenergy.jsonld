  "@id": "https://w3id.org/cdif/xas/facilityenergy",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Facility energy",
    "@language": "en"
  },
  "definition": {
    "@value": "The energy of the current stored in the synchrotron storage ring. (XDI)",
    "@language": "en"
  },
  "note": {
    "@value": "in XDI this is a property of the Facility, so include 'facility' prefix. The beam energy is the product of the ring current (particle flux, typically electrons) and the particle energy.  The beam energy is reported in Joules, particle energe typically in electron volts. Have to look at example data to determine how this is being used.",
    "@language": "en"
  },
  "inScheme": {
    "@id": "https://w3id.org/cdif/xas/CDIF4XAS_Reference_Concepts"
  },
  "seeAlso": "https://manual.nexusformat.org/classes/base_classes/NXsource.html#nxsource-energy-field",
  "foaf:focus": {
    "@id": "http://purl.org/nexusformat/definitions/Field/NXsource/energy"
  },
  "references": [
    "https://github.com/XraySpectroscopy/XAS-Data-Interchange/blob/master/specification/dictionary.md",
