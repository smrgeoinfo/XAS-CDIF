      "schema:additionalProperty": [
        {
          "@type": [
            "schema:PropertyValue"
          ],
          "schema:propertyID": [
            {
              "@id": "xas:edge_energy"
            }
          ],
          "schema:value": "12658.0",
          "schema:name": "edge_energy",
          "schema:description": "When setting up an XAS scan, the analyst tells the acquisition software which absorption edge they're targeting (e.g., Fe K-edge at 7112 eV, Cu K-edge at 8979 eV). The software uses this value to define the scan energy range — typically scanning from some energy below the edge to some energy above it, with denser energy point spacing near the edge and coarser spacing further away. The edge energy value determines where the scan is centered and how the energy grid is constructed. (from Claude)"
        }
      ],
      "schema:startDate": "2008-04-10T21:58:50",
