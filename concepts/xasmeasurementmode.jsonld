  "@id": "https://w3id.org/cdif/xas/xasmeasurementmode",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "XAS measurement mode",
    "@language": "en"
  },
  "definition": {
    "@value": "Detection method used for observing the sample absorption.",
    "@language": "en"
  },
  "note": {
    "@value": "Property of experiment; controlled list of process being monitored to obtain the spectrum.  One of {'Total Electron Yield' , 'Partial Electron Yield' , 'Auger Electron Yield' , 'Fluorescence Yield' , 'Transmission'}.",
    "@language": "en"
  },
