  "@id": "https://w3id.org/cdif/xas/detectortype",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Detector type",
    "@language": "en"
  },
  "definition": {
    "@value": "Kind of detector used to measure X-ray intensities.",
    "@language": "en"
  },
  "note": {
    "@value": "property of detector instrument; description of how x-ray intensity is measured. NEXUS examples:  He3 gas cylinder, He3 PSD, scintillator, fission chamber, proportion counter, ion chamber, ccd, pixel, image plate, CMOS. ",
    "@language": "en"
  },
