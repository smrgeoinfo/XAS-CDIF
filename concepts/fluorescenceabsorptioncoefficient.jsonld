  "@id": "https://w3id.org/cdif/xas/fluorescenceabsorptioncoefficient",
  "@type": "skos:Concept",
  "prefLabel": {
    "@value": "Fluorescence absorption coefficient",
    "@language": "en"
  },
  "notation": "mufluor",
  "definition": {
    "@value": "The fluorescence absorption coefficient is calculated as the natural log of the ratio of emitted fluorescence intensity over transmitted x-ray intensity, divided by the thickness of the sample.",
    "@language": "en"
  },
  "note": {
    "@value": "The fluorescence intensity is proportional to the absorbed fraction of the incident intensity. Fluorescence is preferred for dilute samples (trace element studies, biological samples, catalysts, geological samples), because the emitted fluorescence is element-specific.",
    "@language": "en"
  },
  "inScheme": {
    "@id": "https://w3id.org/cdif/xas/CDIF4XAS_Reference_Concepts"
  },
  "references": [
    "https://github.com/XraySpectroscopy/XAS-Data-Interchange/blob/master/specification/dictionary.md",
    "https://docs.xrayabsorption.org/NXxas/Q2XAFS2024_data.pdf",
    "https://doi.org/10.5281/zenodo.14920226"
  ]
}
